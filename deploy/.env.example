# BlogApp Production Environment Variables
# Copy this file to .env and fill in the values

# PostgreSQL
POSTGRES_USER=blogapp
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=blogapp

# Redis
REDIS_PASSWORD=your_redis_password_here

# RabbitMQ
RABBITMQ_USER=blogapp
RABBITMQ_PASS=your_rabbitmq_password_here

# JWT
JWT_SECRET=your_very_long_jwt_secret_key_at_least_32_characters

# Admin User
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here

# AI Agent Configuration (ZhipuAI)
# Get your API key from https://bigmodel.cn/
ZHIPUAI_API_KEY=your_zhipuai_api_key_here
LLM_MODEL=glm-4-flash

