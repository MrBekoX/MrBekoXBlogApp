# Database Configuration
POSTGRES_USER=blogapp_user
POSTGRES_PASSWORD=your_strong_password_here_change_this
POSTGRES_DB=blogdb

# JWT Configuration
JWT_SECRET=your_super_secret_key_at_least_32_characters_long_change_this
JWT_ISSUER=BlogApp
JWT_AUDIENCE=BlogApp
JWT_EXPIRATION_MINUTES=60

# Application URLs
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8080/api

# Port Configuration (optional, defaults shown)
HTTP_PORT=80
HTTPS_PORT=443
API_PORT=8080
FRONTEND_PORT=3000

# Note: ConnectionStrings and JwtSettings are configured via environment variables
# in docker-compose.prod.yml. For local development, use appsettings.Development.json
# or set these environment variables:
# ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=blogdb;Username=postgres;Password=postgres
# ConnectionStrings__Redis=localhost:6379
# JwtSettings__Secret=your-secret-key-here
# JwtSettings__Issuer=BlogApp
# JwtSettings__Audience=BlogApp
# JwtSettings__ExpirationMinutes=60
# CorsOrigins__0=http://localhost:3000
# CorsOrigins__1=https://localhost:3000

