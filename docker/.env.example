# ===========================================
# BlogApp Environment Configuration (Development)
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ===========================================
# Database Configuration
# ===========================================

# Postgres Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=blogdb_dev

# Redis Configuration (optional)
REDIS_PASSWORD=your_redis_password_here

# RabbitMQ Configuration
RABBITMQ_USER=blogapp
RABBITMQ_PASS=your_strong_rabbitmq_password_min_8_chars

# ===========================================
# ASP.NET Core Application Settings
# ===========================================

# JWT Settings (minimum 32 characters)
JwtSettings__Secret=your-jwt-secret-key-minimum-32-characters-long

# Admin User (created on first startup)
AdminUser__Email=admin@example.com
AdminUser__UserName=admin
AdminUser__Password=your-strong-admin-password-min-12-chars

# ===========================================
# Ollama Configuration (AI Agent)
# ===========================================

# Model to use (phi4-mini, qwen3.5:2b for 4GB VRAM, qwen3.5:4b for 6GB VRAM, qwen3.5:7b for 10GB+)
OLLAMA_MODEL=phi4-mini

# Request timeout in seconds
OLLAMA_TIMEOUT=120

# Context window size
OLLAMA_NUM_CTX=4096

# Temperature (0.0 - 2.0)
OLLAMA_TEMPERATURE=0.7

# ===========================================
# AI Agent Standby Mode (Cost Optimization)
# ===========================================

# Enable low-cost standby mode when idle (default: true)
# When enabled, AI agent pauses heavy consumers and model state after IDLE_TIMEOUT_SECONDS
IDLE_SHUTDOWN_ENABLED=true

# Idle timeout in seconds before standby mode activates (default: 1800 = 30 minutes)
IDLE_TIMEOUT_SECONDS=1800

# Cloudflare Turnstile (optional but required once anonymous chat quota enters verification mode)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ===========================================
# Internal Service Auth (AI Agent <-> Backend)
# ===========================================

# Shared key for internal service-to-service authentication
# MUST be the same in both Backend and AI Agent
INTERNAL_SERVICE_AUTH_KEY=your-internal-service-auth-key-here
