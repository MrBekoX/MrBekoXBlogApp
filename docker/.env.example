# ===========================================
# BlogApp Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ===========================================
# Database Configuration
# ===========================================

# Postgres Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=blogdb_dev

# Redis Configuration (optional)
REDIS_PASSWORD=your_redis_password_here

# RabbitMQ Configuration
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ===========================================
# ASP.NET Core Application Settings
# ===========================================

# JWT Settings (minimum 32 characters)
JwtSettings__Secret=your-jwt-secret-key-minimum-32-characters-long

# Admin User (created on first startup)
AdminUser__Email=admin@example.com
AdminUser__UserName=admin
AdminUser__Password=your-strong-admin-password-min-12-chars

# Connection Strings
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=blogdb_dev;Username=postgres;Password=your_secure_password_here
ConnectionStrings__Redis=localhost:6379

# RabbitMQ Settings for Backend
RabbitMQ__HostName=rabbitmq
RabbitMQ__Port=5672
RabbitMQ__UserName=guest
RabbitMQ__Password=guest
RabbitMQ__Enabled=true

# ===========================================
# AI Agent Service Configuration
# ===========================================

# ZhipuAI Configuration
# Get your API key from https://bigmodel.cn/
ZHIPUAI_API_KEY=your-zhipuai-api-key-here
LLM_MODEL=glm-4

# AI Agent Service Settings
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
REDIS_URL=redis://redis:6379/0
BACKEND_API_URL=http://backend:8080/api/v1
DEBUG=false
