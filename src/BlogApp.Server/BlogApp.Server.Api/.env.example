# ===========================================
# BlogApp Backend Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ===========================================
# Database Configuration
# ===========================================

# PostgreSQL Connection String
# Format: Host=hostname;Port=5432;Database=dbname;Username=username;Password=password
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=blogdb_dev;Username=blogapp_user;Password=your_secure_password_here

# Redis Connection String
# Format: localhost:6379,password=your_password
ConnectionStrings__Redis=localhost:6379,password=your_redis_password

# ===========================================
# JWT Settings
# ===========================================

# JWT Secret Key (minimum 32 characters recommended)
# Generate with: openssl rand -hex 32
JwtSettings__Secret=your-jwt-secret-key-minimum-32-characters-long

# JWT Issuer and Audience
JwtSettings__Issuer=BlogApp
JwtSettings__Audience=BlogApp

# Token Expiration (in minutes)
JwtSettings__ExpirationMinutes=60

# ===========================================
# Admin User (created on first startup)
# ===========================================

# Admin user credentials
AdminUser__Email=admin@example.com
AdminUser__UserName=admin
AdminUser__Password=your-strong-admin-password-min-12-chars
AdminUser__FirstName=Admin

# ===========================================
# RabbitMQ Configuration
# ===========================================

# RabbitMQ Connection Settings
RabbitMQ__HostName=localhost
RabbitMQ__Port=5672
RabbitMQ__UserName=blogapp
RabbitMQ__Password=your_rabbitmq_password
RabbitMQ__VirtualHost=/
RabbitMQ__ExchangeName=blog.events

# Enable/disable RabbitMQ messaging
RabbitMQ__Enabled=true

# ===========================================
# CORS Configuration
# ===========================================

# Allowed origins (comma-separated)
CorsOrigins=http://localhost:3000,http://localhost:5173,https://localhost:3000

# ===========================================
# OpenTelemetry (Optional)
# ===========================================

# OTEL Endpoint (e.g., Jaeger, Prometheus)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
