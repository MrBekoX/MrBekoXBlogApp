{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_DB_HOST;Port=5432;Database=blogdb;Username=YOUR_USERNAME;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true",
    "Redis": "YOUR_REDIS_HOST:6379,password=YOUR_REDIS_PASSWORD"
  },
  "JwtSettings": {
    "Secret": "YOUR-PRODUCTION-SECRET-KEY-MINIMUM-64-CHARACTERS-VERY-SECURE",
    "Issuer": "BlogApp",
    "Audience": "BlogApp",
    "ExpirationMinutes": 30
  },
  "AdminUser": {
    "Email": "admin@yourdomain.com",
    "UserName": "admin",
    "Password": "YOUR-VERY-STRONG-PRODUCTION-PASSWORD",
    "FirstName": "Admin"
  },
  "CorsOrigins": [
    "https://yourdomain.com",
    "https://www.yourdomain.com"
  ],
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 30
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 300
      },
      {
        "Endpoint": "post:/api/auth/login",
        "Period": "1m",
        "Limit": 3
      },
      {
        "Endpoint": "post:/api/auth/register",
        "Period": "1h",
        "Limit": 5
      }
    ]
  },
  "AllowedHosts": "yourdomain.com;www.yourdomain.com"
}
