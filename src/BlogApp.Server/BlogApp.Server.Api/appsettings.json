{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "AspNetCoreRateLimit": "Debug"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "",
    "Redis": ""
  },
  "JwtSettings": {
    "Secret": "",
    "Issuer": "BlogApp",
    "Audience": "BlogApp",
    "ExpirationMinutes": 60
  },
  "AdminUser": {
    "Email": "",
    "UserName": "",
    "Password": "",
    "FirstName": "Admin"
  },
  "CorsOrigins": [],
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "IpWhitelist": [],
    "ClientWhitelist": [],
    "QuotaExceededResponse": {
      "Content": "{{ \"message\": \"API cagrisi kotasi asildi! Maksimum {0} istek / {1}. Lutfen bekleyin.\", \"retryAfter\": \"{2}\" }}",
      "ContentType": "application/json",
      "StatusCode": 429
    },
    "EndpointWhitelist": [
      "get:/hubs/*"
    ],
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 300
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 3000
      },
      {
        "Endpoint": "post:/api/v1/auth/login",
        "Period": "1m",
        "Limit": 5
      },
      {
        "Endpoint": "post:/api/v1/auth/register",
        "Period": "1h",
        "Limit": 10
      },
      {
        "Endpoint": "post:/api/v1/media/upload/image",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "post:/api/v1/media/upload/images",
        "Period": "5m",
        "Limit": 5
      }
    ]
  },
  "ChatAbuseProtection": {
    "Enabled": true,
    "AnonymousOnly": true,
    "SoftRequestsPerMinute": 4,
    "HardRequestsPerMinute": 12,
    "SoftRequestsPerHour": 40,
    "HardRequestsPerHour": 180,
    "SoftEstimatedTokensPerDay": 60000,
    "HardEstimatedTokensPerDay": 150000,
    "TurnstileBypassMinutes": 20,
    "TurnstileAction": "chat"
  },
  "Turnstile": {
    "SiteKey": "",
    "SecretKey": "",
    "VerifyUrl": "https://challenges.cloudflare.com/turnstile/v0/siteverify"
  },
  "AllowedHosts": "*",
  "RabbitMQ": {
    "HostName": "",
    "Port": 5672,
    "UserName": "",
    "Password": "",
    "VirtualHost": "/",
    "ExchangeName": "blog.events",
    "Enabled": false,
    "PrefetchCount": 10
  }
}
