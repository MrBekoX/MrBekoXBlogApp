# ===========================================
# AI Agent Service Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ===========================================
# Ollama Configuration
# ===========================================

# Ollama Base URL
OLLAMA_BASE_URL=http://localhost:11434

# Model to use (phi4-mini, qwen3.5:2b for 4GB VRAM, qwen3.5:4b for 6GB VRAM, qwen3.5:7b for 10GB+)
OLLAMA_MODEL=phi4-mini

# Request timeout in seconds
OLLAMA_TIMEOUT=120

# Context window size
OLLAMA_NUM_CTX=4096

# Temperature (0.0 - 2.0)
OLLAMA_TEMPERATURE=0.7

# ===========================================
# Redis Configuration
# ===========================================

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# ===========================================
# RabbitMQ Configuration
# ===========================================

# RabbitMQ connection settings
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=blogapp
RABBITMQ_PASS=your_rabbitmq_password
RABBITMQ_VHOST=/

# ===========================================
# Worker Resilience (Timeout/Retry)
# ===========================================

# Timeout for worker operations (analysis/chat/indexing)
WORKER_OPERATION_TIMEOUT_SECONDS=180

# Timeout for broker publish operations
BROKER_PUBLISH_TIMEOUT_SECONDS=10

# Retry policy for transient worker failures (reduced to prevent chain retries)
WORKER_RETRY_ATTEMPTS=1
WORKER_RETRY_BASE_DELAY_SECONDS=0.25
WORKER_RETRY_MAX_BACKOFF_SECONDS=2.0

# Broker poison-message strategy
BROKER_MESSAGE_MAX_RETRIES=5
BROKER_LOCK_RETRY_DELAY_SECONDS=2.0
BROKER_QUARANTINE_PREVIEW_BYTES=4096
BROKER_QUARANTINE_STORE_BODY_MAX_BYTES=262144
ENABLE_POISON_RUNBOOK_HOOK=true
BROKER_CONSUMER_PREFETCH_COUNT=16
BROKER_CONSUMER_CONCURRENCY=8
BROKER_BACKLOG_WARN_THRESHOLD=5000

# Chat tool budgets (timeout/retry) - reduced to prevent chain retries
TOOL_DEFAULT_TIMEOUT_SECONDS=30
TOOL_RAG_TIMEOUT_SECONDS=15
TOOL_WEB_SEARCH_TIMEOUT_SECONDS=20
TOOL_LLM_TIMEOUT_SECONDS=90
TOOL_RETRY_ATTEMPTS=1
RAG_EXPAND_TIMEOUT_SECONDS=5
TOOL_RETRY_BASE_DELAY_SECONDS=0.2
TOOL_RETRY_MAX_BACKOFF_SECONDS=2.0

# Reasoning policy
REASONING_CRITIQUE_ENABLED=true
REASONING_CRITIQUE_MAX_REPAIRS=1
REASONING_CODE_REQUEST_MIN_OVERLAP=0.20

# ===========================================
# LangGraph Multi-Agent Configuration
# ===========================================

# Enable LangGraph-based message processing with Supervisor
AGENT_USE_LANGGRAPH=true

# LangGraph checkpoint TTL in seconds (default 24h)
AGENT_CHECKPOINT_TTL=86400

# Maximum ReAct reasoning iterations
AGENT_MAX_REACT_STEPS=5

# ===========================================
# Autonomous Agent Configuration
# ===========================================

# Enable autonomous agent with planning capabilities
AGENT_AUTONOMOUS_ENABLED=true

# Use hybrid mode: ReAct for simple, Autonomous for complex queries
AGENT_HYBRID_MODE=true

# Maximum steps in an execution plan (optimized for Gemma3:4b)
AGENT_MAX_PLAN_STEPS=4

# Maximum total iterations for autonomous execution
AGENT_MAX_TOTAL_ITERATIONS=10

# Maximum time for autonomous execution in seconds
AGENT_MAX_TIME_SECONDS=120

# Maximum LLM calls per autonomous execution
AGENT_MAX_LLM_CALLS=15

# Hard timeout for VerificationAgent LLM call (seconds)
# On timeout, original response is returned unmodified
AGENT_VERIFICATION_TIMEOUT_SECONDS=20

# Confidence threshold for early termination
AGENT_CONFIDENCE_THRESHOLD=0.7

# Enable episodic memory for learning from past executions
AGENT_EPISODIC_MEMORY_ENABLED=true

# Enable LLM-based dynamic routing
AGENT_DYNAMIC_ROUTING=true

# ===========================================
# Backend API Configuration
# ===========================================

# Backend API URL for saving analysis results
BACKEND_API_URL=http://localhost:5116/api/v1

# ===========================================
# Server Settings
# ===========================================

# Server host binding
HOST=0.0.0.0

# Server port
PORT=8000

# Debug mode (true/false)
DEBUG=false

# ===========================================
# ChromaDB Configuration
# ===========================================

# ChromaDB persistent storage directory
CHROMA_PERSIST_DIR=./chroma_data

# Force reset all ChromaDB collections on startup (nuclear option for dimension mismatch)
# Set to true if you get "InvalidArgumentError: Collection expecting embedding with dimension of X, got Y"
# WARNING: This will delete all indexed articles and cached queries!
CHROMA_FORCE_RESET=false

# ===========================================
# OAuth 2.0 (Optional - for M2M auth)
# ===========================================

# OAuth introspection URL
# oauth_introspection_url=https://your-auth-server.com/introspect

# OAuth client credentials
# oauth_client_id=your_client_id
# oauth_client_secret=your_client_secret

# Internal service key for backend authorization decisions
# Sent via HTTP header: X-Service-Key
# INTERNAL_SERVICE_AUTH_KEY=change_this_to_a_long_random_value

# ===========================================
# Security Settings
# ===========================================

# Enable semantic jailbreak detection
ENABLE_SEMANTIC_DETECTION=true

# Jailbreak confidence threshold
JAILBREAK_CONFIDENCE_THRESHOLD=0.6

# Log only mode (set to true in production for monitoring)
JAILBREAK_LOG_ONLY=true

# Red team mode (for testing - NEVER enable in production)
ENABLE_RED_TEAM_MODE=false
HF_TOKEN=hf_xxxxxxxxxxxxx 

# ===========================================
# Memory Configuration
# ===========================================

# Enable episodic memory for agent learning
AGENT_EPISODIC_MEMORY_ENABLED=true

# Short-term memory (Redis) settings
MEMORY_STM_MAX_MESSAGES=100
MEMORY_STM_TTL_SECONDS=86400

# Long-term memory (ChromaDB) settings
MEMORY_LTM_MAX_EPISODES=1000

# LangGraph checkpoint persistence
MEMORY_CHECKPOINT_ENABLED=true
MEMORY_CHECKPOINT_TTL_SECONDS=86400
