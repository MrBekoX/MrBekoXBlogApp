# ===========================================
# AI Agent Service Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ===========================================
# Ollama Configuration
# ===========================================

# Ollama Base URL
OLLAMA_BASE_URL=http://localhost:11434

# Model to use (gemma3:4b for 6GB VRAM, gemma3:12b for 16GB+)
OLLAMA_MODEL=gemma3:4b

# Request timeout in seconds
OLLAMA_TIMEOUT=120

# Context window size
OLLAMA_NUM_CTX=4096

# Temperature (0.0 - 2.0)
OLLAMA_TEMPERATURE=0.7

# ===========================================
# Redis Configuration
# ===========================================

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# ===========================================
# RabbitMQ Configuration
# ===========================================

# RabbitMQ connection settings
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=blogapp
RABBITMQ_PASS=your_rabbitmq_password
RABBITMQ_VHOST=/

# ===========================================
# Backend API Configuration
# ===========================================

# Backend API URL for saving analysis results
BACKEND_API_URL=http://localhost:5116/api/v1

# ===========================================
# Server Settings
# ===========================================

# Server host binding
HOST=0.0.0.0

# Server port
PORT=8000

# Debug mode (true/false)
DEBUG=false

# ===========================================
# ChromaDB Configuration
# ===========================================

# ChromaDB persistent storage directory
CHROMA_PERSIST_DIR=./chroma_data

# ===========================================
# OAuth 2.0 (Optional - for M2M auth)
# ===========================================

# OAuth introspection URL
# oauth_introspection_url=https://your-auth-server.com/introspect

# OAuth client credentials
# oauth_client_id=your_client_id
# oauth_client_secret=your_client_secret

# ===========================================
# Security Settings
# ===========================================

# Enable semantic jailbreak detection
ENABLE_SEMANTIC_DETECTION=true

# Jailbreak confidence threshold
JAILBREAK_CONFIDENCE_THRESHOLD=0.6

# Log only mode (set to true in production for monitoring)
JAILBREAK_LOG_ONLY=true

# Red team mode (for testing - NEVER enable in production)
ENABLE_RED_TEAM_MODE=false
